# ── AI Pipeline Configuration ─────────────────────────────────────────────────
# See AI-PIPELINES.md for full documentation.

# Global defaults (apply to all pipelines unless overridden)
AI_PROVIDER=anthropic              # anthropic | openai-compatible
AI_MODEL=claude-sonnet-4-6        # Model ID for the selected provider

# Provider API keys (server-side only, never sent to browser)
ANTHROPIC_API_KEY=                  # Required when AI_PROVIDER=anthropic
AI_API_KEY=                         # Required when AI_PROVIDER=openai-compatible
                                    # Works with OpenAI, Groq, Together, OpenRouter, Mistral, etc.

# OpenAI-compatible base URL (defaults to https://api.openai.com/v1)
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_BASE_URL=https://api.together.xyz/v1
# AI_BASE_URL=https://openrouter.ai/api/v1

# Per-pipeline overrides (optional — override global defaults for specific pipelines)
# ATMOSPHERE_AI_PROVIDER=openai-compatible
# ATMOSPHERE_AI_MODEL=gpt-4o
