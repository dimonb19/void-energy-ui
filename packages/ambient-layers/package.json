{
  "name": "@void-energy/ambient-layers",
  "version": "0.5.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Immersive full-viewport overlay layers for Void Energy (Atmosphere, Psychology, Action, Environment).",
  "author": "DGRS Labs Pte. Ltd. <biz@dgrslabs.com>",
  "homepage": "https://github.com/voidenergy/void-energy-premium#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voidenergy/void-energy-premium.git",
    "directory": "packages/ambient-layers"
  },
  "bugs": {
    "url": "https://github.com/voidenergy/void-energy-premium/issues"
  },
  "keywords": [
    "ambient",
    "overlay",
    "weather-effects",
    "svelte",
    "canvas",
    "void-energy"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./atmosphere": {
      "types": "./dist/svelte/AtmosphereLayer.svelte",
      "svelte": "./dist/svelte/AtmosphereLayer.svelte",
      "default": "./dist/svelte/AtmosphereLayer.svelte"
    },
    "./psychology": {
      "types": "./dist/svelte/PsychologyLayer.svelte",
      "svelte": "./dist/svelte/PsychologyLayer.svelte",
      "default": "./dist/svelte/PsychologyLayer.svelte"
    },
    "./action": {
      "types": "./dist/svelte/ActionLayer.svelte",
      "svelte": "./dist/svelte/ActionLayer.svelte",
      "default": "./dist/svelte/ActionLayer.svelte"
    },
    "./environment": {
      "types": "./dist/svelte/EnvironmentLayer.svelte",
      "svelte": "./dist/svelte/EnvironmentLayer.svelte",
      "default": "./dist/svelte/EnvironmentLayer.svelte"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./styles": {
      "types": "./dist/styles/styles.d.ts",
      "default": "./dist/styles/ambient-layers.css"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "devDependencies": {
    "sass-embedded": "^1.93.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  }
}
