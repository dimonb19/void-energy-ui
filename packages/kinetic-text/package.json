{
  "name": "@void-energy/kinetic-text",
  "version": "0.2.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Premium kinetic text engine for Void Energy — character-level reveals, effects library, and TTS sync.",
  "author": "DGRS Labs Pte. Ltd. <biz@dgrslabs.com>",
  "homepage": "https://github.com/void-energy/void-energy-premium#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/void-energy/void-energy-premium.git",
    "directory": "packages/kinetic-text"
  },
  "bugs": {
    "url": "https://github.com/void-energy/void-energy-premium/issues"
  },
  "keywords": [
    "kinetic-text",
    "text-reveal",
    "svelte",
    "animation",
    "tts",
    "void-energy"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./component": {
      "types": "./dist/svelte/KineticText.svelte",
      "svelte": "./dist/svelte/KineticText.svelte",
      "default": "./dist/svelte/KineticText.svelte"
    },
    "./tts-block": {
      "types": "./dist/svelte/TtsKineticBlock.svelte",
      "svelte": "./dist/svelte/TtsKineticBlock.svelte",
      "default": "./dist/svelte/TtsKineticBlock.svelte"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./adapters/void-energy-host": {
      "types": "./dist/adapters/void-energy-host.d.ts",
      "default": "./dist/adapters/void-energy-host.js"
    },
    "./skeleton": {
      "types": "./dist/svelte/KineticSkeleton.svelte",
      "svelte": "./dist/svelte/KineticSkeleton.svelte",
      "default": "./dist/svelte/KineticSkeleton.svelte"
    },
    "./styles": {
      "types": "./dist/styles/styles.d.ts",
      "default": "./dist/styles/kinetic-text.css"
    },
    "./tts": {
      "types": "./dist/tts/index.d.ts",
      "default": "./dist/tts/index.js"
    },
    "./tts/providers": {
      "types": "./dist/tts/providers/index.d.ts",
      "default": "./dist/tts/providers/index.js"
    }
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "devDependencies": {
    "sass-embedded": "^1.93.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  }
}
