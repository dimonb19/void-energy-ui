/*
 * 🤖 AUTO-GENERATED — DO NOT EDIT
 * @void-energy/tailwind — foundation tokens (L0)
 * Source of truth: src/config/design-tokens.ts
 *
 * These are the density-scaled and atmosphere-independent tokens.
 * Atmospheres (atmospheres/*.css) and physics (physics/*.css) override
 * a narrower surface on top.
 */

:root {
  /* Base unit (4px) + density default. density.css overrides via [data-density]. */
  --unit: 0.25rem;
  --density: 1;

  /* Spacing scale — multiplies by --density (0.75 compact, 1 default, 1.25 comfortable). */
  --space-xs: calc(2 * var(--unit) * var(--density, 1));
  --space-sm: calc(4 * var(--unit) * var(--density, 1));
  --space-md: calc(6 * var(--unit) * var(--density, 1));
  --space-lg: calc(8 * var(--unit) * var(--density, 1));
  --space-xl: calc(12 * var(--unit) * var(--density, 1));
  --space-2xl: calc(16 * var(--unit) * var(--density, 1));
  --space-3xl: calc(24 * var(--unit) * var(--density, 1));
  --space-4xl: calc(32 * var(--unit) * var(--density, 1));
  --space-5xl: calc(40 * var(--unit) * var(--density, 1));

  /* Layout + control geometry. */
  --nav-height: calc(16 * var(--unit) * var(--density, 1));
  --size-touch-min: 2.75rem;
  --control-height: max(2.25rem, calc(2.75rem * var(--density, 1)));
  --control-padding-x: var(--space-sm);
  --control-padding-y: calc(var(--space-xs) * 0.75);
  --breadcrumbs-height: calc(var(--space-md) + var(--space-xs) * 2);
  --scrollbar-width: 6px;

  /* Radius scale. physics/retro.css zeroes these for CRT aesthetic. */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --radius-full: 9999px;

  /* Z-index semantic scale. */
  --z-sunk: -1;
  --z-floor: 0;
  --z-base: 1;
  --z-decorate: 2;
  --z-float: 10;
  --z-sticky: 20;
  --z-header: 40;
  --z-dropdown: 50;
  --z-overlay: 90;

  /* Font sizes — fluid clamps from design-tokens.ts. */
  --font-size-caption: clamp(0.6875rem, 0.66rem + 0.15vw, 0.75rem);
  --font-size-small: clamp(0.75rem, 0.7rem + 0.2vw, 0.875rem);
  --font-size-body: clamp(0.875rem, 0.8rem + 0.2vw, 1rem);
  --font-size-h6: clamp(0.875rem, 0.8rem + 0.2vw, 1rem);
  --font-size-h5: clamp(1rem, 0.95rem + 0.5vw, 1.25rem);
  --font-size-h4: clamp(1.125rem, 1rem + 1vw, 1.5rem);
  --font-size-h3: clamp(1.25rem, 1.1rem + 1.5vw, 2rem);
  --font-size-h2: clamp(1.5rem, 1.25rem + 2vw, 2.5rem);
  --font-size-h1: clamp(2rem, 1.5rem + 3vw, 3.5rem);

  /* Line heights. */
  --line-height-caption: 1.4;
  --line-height-small: 1.5;
  --line-height-body: 1.5;
  --line-height-h6: 1.45;
  --line-height-h5: 1.4;
  --line-height-h4: 1.3;
  --line-height-h3: 1.2;
  --line-height-h2: 1.15;
  --line-height-h1: 1.1;

  /* Letter spacing. */
  --letter-spacing-caption: 0.02em;
  --letter-spacing-small: 0.01em;
  --letter-spacing-body: 0.005em;
  --letter-spacing-h6: 0.005em;
  --letter-spacing-h5: 0em;
  --letter-spacing-h4: 0em;
  --letter-spacing-h3: -0.01em;
  --letter-spacing-h2: -0.015em;
  --letter-spacing-h1: -0.02em;

  /* Font weights. */
  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --font-weight-extrabold: 800;

  /*
   * Font families — default stacks only. Consumers override via --font-heading/body/mono
   * or via atmosphere CSS (--font-atmos-heading / --font-atmos-body). Session 2 wires
   * atmosphere fonts on top so the active atmosphere can change them.
   */
  --font-heading: 'Hanken Grotesk', sans-serif;
  --font-body: 'Inter', sans-serif;
  --font-mono: 'Courier Prime', monospace;

  /* Structural constants (modal widths, tooltip, dialog gutters). */
  --modal-width-xs: 24rem;
  --modal-width-sm: 32rem;
  --modal-width-md: 40rem;
  --modal-width-lg: 64rem;
  --modal-width-xl: 75rem;
  --tooltip-max-width: 250px;
  --dialog-gutter: var(--space-xl);
  --dialog-gutter-lg: var(--space-2xl);

  /* Safe-area insets (iOS/Android edge-to-edge). */
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --safe-left: env(safe-area-inset-left, 0px);
  --safe-right: env(safe-area-inset-right, 0px);
}
