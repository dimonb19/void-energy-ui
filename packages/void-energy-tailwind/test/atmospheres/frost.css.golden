  --color-error-light: oklch(from #ff3c40 calc(l * 1.25) c h);
  --color-error-dark: oklch(from #ff3c40 calc(l * 0.75) c h);
  --color-error-subtle: oklch(from #ff3c40 l c h / 0.15);
