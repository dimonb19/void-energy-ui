[data-physics='glass'] {
  --speed-instant: 0.1s;
  --speed-fast: 0.2s;
  --speed-base: 0.3s;
  --speed-slow: 0.5s;
  --delay-cascade: 50ms;
  --delay-sequence: 100ms;
  --ease-spring-gentle: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  --ease-spring-snappy: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-spring-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  --ease-flow: linear;
  --physics-blur: 20px;
  --physics-border-width: 1px;
  --lift: -3px;
  --scale: 1.02;
  --radius-base: 8px;
  --radius-full: 9999px;
  --surface-bg: linear-gradient(
    to bottom,
    color-mix(in oklch, var(--bg-surface), var(--energy-secondary) 10%) 0%,
    var(--bg-surface) 100%
  );
  --shadow-sunk: inset 0 2px 4px color-mix(in oklch, var(--bg-canvas) 60%, transparent 40%);
  --shadow-float:
    0 1px 3px color-mix(in oklch, var(--bg-canvas) 25%, transparent 75%),
    0 6px 20px -4px color-mix(in oklch, var(--bg-canvas) 35%, transparent 65%);
  --shadow-lift:
    0 8px 28px -4px color-mix(in oklch, var(--bg-canvas) 35%, transparent 65%),
    0 0 12px color-mix(in oklch, var(--energy-primary) 35%, transparent 65%);
}
