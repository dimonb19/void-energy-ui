{
  "name": "@void-energy/tailwind",
  "version": "0.1.0",
  "description": "Void Energy's design system brain as a framework-agnostic Tailwind CSS v4 preset. Atmospheres, physics presets, density scaling, semantic tokens for any framework.",
  "type": "module",
  "license": "BUSL-1.1",
  "author": "DGRS Labs Pte. Ltd. <biz@dgrslabs.com>",
  "homepage": "https://github.com/void-energy/void-energy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/void-energy/void-energy.git",
    "directory": "packages/void-energy-tailwind"
  },
  "bugs": {
    "url": "https://github.com/void-energy/void-energy/issues"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwindcss-v4",
    "design-system",
    "design-tokens",
    "css",
    "svelte",
    "astro",
    "void-energy"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "bin": {
    "void-energy": "./bin/void-energy.js"
  },
  "exports": {
    "./theme.css": "./dist/theme.css",
    "./theme-no-container.css": "./dist/theme-no-container.css",
    "./tokens.css": "./dist/tokens.css",
    "./density.css": "./dist/density.css",
    "./components.css": "./dist/components.css",
    "./atmospheres/*": "./dist/atmospheres/*",
    "./physics/*": "./dist/physics/*",
    "./bridges/*": "./dist/bridges/*",
    "./atmospheres.json": "./dist/atmospheres.json",
    "./builtins.json": "./dist/builtins.json",
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./head": {
      "types": "./dist/head.d.ts",
      "import": "./dist/head.js",
      "require": "./dist/head.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js",
      "require": "./dist/generator.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": false
    }
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "tsx": "^4.21.0"
  },
  "scripts": {
    "build": "npm --prefix ../.. run build:tokens -- --target=l0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.10.1"
  }
}
