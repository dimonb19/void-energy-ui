{
  "name": "void-energy-ui",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx scripts/local-dev.ts",
    "build": "npm run build:tokens && npm run build:tailwind && npm run build:kinetic-text && npm run build:ambient-layers && astro build",
    "build:tokens": "tsx scripts/generate-tokens.ts",
    "build:tailwind": "npm --workspace @void-energy/tailwind run build",
    "build:kinetic-text": "npm --workspace @void-energy/kinetic-text run build",
    "build:ambient-layers": "npm --workspace @void-energy/ambient-layers run build",
    "build:mcp": "npm --workspace @void-energy/mcp run build",
    "build:mcp:data": "tsx packages/void-energy-mcp/scripts/build-data.ts",
    "build:skill": "tsx scripts/build-skill.ts",
    "preview": "astro preview",
    "scan": "tsx scripts/scan-physics.ts",
    "atmosphere-md": "tsx scripts/atmosphere-md.ts",
    "lint:design-md": "design.md lint DESIGN.md",
    "check:design-md": "tsx scripts/atmosphere-md.ts spec-verify",
    "check:registry": "tsx scripts/check-component-registry.ts",
    "check:skill": "tsx scripts/check-skill.ts",
    "check:kinetic-text": "npm --workspace @void-energy/kinetic-text run check",
    "check:ambient-layers": "npm --workspace @void-energy/ambient-layers run check",
    "check:mcp": "npm --workspace @void-energy/mcp run check",
    "test:mcp": "vitest run tests/mcp-safety-merge-equivalence.test.ts",
    "smoke:mcp": "npm run build:mcp && tsx packages/void-energy-mcp/scripts/smoke-test.ts",
    "check": "npm run check:registry && svelte-check --tsconfig ./tsconfig.json && npm run lint:design-md && npm run check:design-md && npm run check:skill && npm run check:mcp && npm run test:mcp",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/svelte": "^7.2.2",
    "@astrojs/vercel": "^9.0.5",
    "@floating-ui/dom": "^1.7.4",
    "@lucide/svelte": "^1.14.0",
    "astro": "^5.16.0",
    "fast-average-color": "^9.5.2",
    "marked": "18.0.2",
    "sanitize-html": "2.17.3",
    "svelte": "^5.43.14",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@google/design.md": "0.1.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/sanitize-html": "2.16.1",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-svelte": "3.4.0",
    "sass-embedded": "^1.93.3",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
