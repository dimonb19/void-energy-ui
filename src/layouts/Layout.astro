---
import '@styles/tailwind-theme.css';
import '@styles/global.scss';

import ThemeScript from '@components/core/ThemeScript.astro';
import UserScript from '@components/core/UserScript.astro';
import LiquidGlassFilter from '@components/core/LiquidGlassFilter.svelte';
import Navigation from '@components/Navigation.svelte';
import Modal from '@components/Modal.svelte';
import Toast from '@components/Toast.svelte';
import { AmbientHost } from '@void-energy/ambient-layers';
import '@void-energy/ambient-layers/styles';

interface Props {
  title?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title = 'Void Energy UI', breadcrumbs } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#010020" />
    <meta
      name="description"
      content='Void Energy is a physics-driven design system that operates on the Triad Architecture, where interfaces are generated by the intersection of Atmosphere (Mood), Physics (Matter), and Mode (Polarity). By enforcing a strict Hybrid Protocol, the system separates structural Geometry (managed via Tailwind) from visual Physics (rendered via SCSS), ensuring that every component remains responsive to user density preferences while maintaining "Material Truth" across all 12+ environmental presets.'
    />
    <meta
      http-equiv="Content-Security-Policy"
      content="upgrade-insecure-requests"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://media.dgrslabs.ink" crossorigin />
    <title>{title}</title>
    <ThemeScript />
    <UserScript />
  </head>
  <body data-has-breadcrumbs={breadcrumbs && breadcrumbs.length > 0 ? '' : undefined}>
    <LiquidGlassFilter client:load />
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Navigation client:load pathname={Astro.url.pathname} breadcrumbs={breadcrumbs} />

    <main id="main-content" class="min-h-screen">
      <slot />
    </main>

    <Modal client:idle />
    <Toast client:idle />
    <AmbientHost client:idle />
  </body>
</html>
