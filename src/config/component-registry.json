        "value:bindable",
        "id",
        "placeholder",
        "autocomplete",
        "zoom",
        "delay",
        "onsubmit",
        "oninput",
        "disabled",
        "class",
        "...rest:input"
      ],
      "slots": [],
      "related": ["edit-field", "generate-field", "combobox"],
      "compose": "Wrap in FormField for label or validation. Use bind:value for reactivity; onsubmit fires on Enter.",
      "example": "<SearchField bind:value={query} placeholder='Search...' />"
    },
